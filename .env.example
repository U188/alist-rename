# ========= AList / OpenList =========
# AList/OpenList 地址，末尾不要带 /
ALIST_URL="http://127.0.0.1:5244"
# AList/OpenList Token；请勿把真实 token 提交到仓库
ALIST_TOKEN="your_alist_token"

# 电视剧/动漫等扫描根目录，多个用英文逗号分隔
TV_ROOTS="/电视剧,/动漫"

# ========= TMDB =========
TMDB_KEY="your_tmdb_key"
TMDB_LANG="zh-CN"
# 官方地址或兼容代理地址
TMDB_API_BASE="https://api.themoviedb.org"

# ========= 风控/重试 =========
ALIST_SLEEP_READ="0.6"
ALIST_SLEEP_WRITE="1.0"
ALIST_RETRIES="6"
ALIST_REFRESH="0"
ON_CONFLICT="suffix"
MOVE_INDIVIDUAL="1"

# ========= 命名/规则 =========
FIX_BARE_SXXEYY="1"
SEASON_FORMAT="S{season:02d}"
SKIP_DIR_REGEX=""

# ========= 归档 =========
# 留空=尽量回来源顶层根；填写=/整理 等则统一归档到固定根
TARGET_ROOT=""
CATEGORY_REGION_MAP="剧集:大陆,港台,欧美,日韩,其他;动漫:大陆,港台,日韩,欧美,其他;电影:大陆,港台,欧美,日韩,其他;纪录片:大陆,港台,欧美,日韩,其他;综艺:大陆,港台,日韩,欧美,其他"

# ========= AI（可选，留空则不调用） =========
AI_BASE_URL="https://api.openai.com/v1"
AI_API_KEY="your_ai_api_key"
AI_MODEL="gpt-4o-mini"
AI_SLEEP="1.2"

# ========= Web UI / 日志 =========
LOG_HOST="0.0.0.0"
LOG_PORT="55255"
LOGUI_TOKEN="change_me"
LOG_FILE=""
STATE_FILE=""
UNDO_FILE=""
